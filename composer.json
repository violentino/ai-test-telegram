{
  "name": "telegram/ton-store-bot",
  "description": "Telegram bot clothing store with card and TON payments",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "slim/slim": "^4.13",
    "slim/psr7": "^1.6",
    "vlucas/phpdotenv": "^5.6",
    "guzzlehttp/guzzle": "^7.9",
    "monolog/monolog": "^3.6",
    "stripe/stripe-php": "^14.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "start": "php -S 0.0.0.0:8080 -t public",
    "post-autoload-dump": [
      "@php -r 'file_exists(\".env\") || copy(\".env.example\", \".env\");'"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}